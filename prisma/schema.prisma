// Prisma schema for Haraj-like classifieds website with auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String?   @unique
  phone         String    @unique
  password      String
  city          String?
  avatar        String?
  isVerified    Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  rating        Float     @default(5.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  listings      Listing[]
  comments      Comment[]
  favorites     Favorite[]
  sessions      Session[]
  accounts      Account[]
  bankAccounts  BankAccount[]
  transactions  Transaction[]
  adminTransactions Transaction[] @relation("AdminTransactions")
  notifications Notification[]
  payments      Payment[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  parentId  String?
  parent    Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryParent")
  listings  Listing[]
  createdAt DateTime  @default(now())
}

model Listing {
  id          String     @id @default(cuid())
  title       String
  description String
  price       Int
  currency    String     @default("ريال")
  city        String
  district    String?
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  images      String     // JSON array of image URLs
  status      String     @default("active") // active, sold, expired
  isFeatured  Boolean    @default(false)
  isVerified  Boolean    @default(false)
  views       Int        @default(0)
  year        Int?       // For cars - year of manufacture
  kilometers  Int?       // For cars
  condition   String?    // new, used
  phone       String
  whatsapp    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  comments    Comment[]
  favorites   Favorite[]
}

model Comment {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  username  String
  content   String
  phone     String?
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ===== PAYMENT / BANK SYSTEM =====

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankName      String
  accountName   String
  iban          String   @unique
  accountNumber String
  swiftCode     String?
  isDefault     Boolean  @default(false)
  transactions  Transaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // deposit, withdrawal, payment_in, payment_out
  amount          Float
  currency        String   @default("ريال")
  status          String   @default("pending") // pending, approved, rejected, completed
  description     String?
  // For withdrawals: which bank account to send money to
  bankAccountId   String?
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])
  // Admin who processed the transaction
  processedById   String?
  processedBy     User?    @relation("AdminTransactions", fields: [processedById], references: [id])
  processedAt     DateTime?
  adminNote       String?
  // Reference / receipt
  reference       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("حراج")
  adminPhone      String   @default("0575015019")
  adminWhatsApp   String   @default("0575015019")
  adminEmail      String?
  adminCity       String   @default("جدة")
  // Admin's bank info for receiving transfers
  adminBankName       String?
  adminAccountName    String?
  adminIBAN           String?
  adminAccountNumber  String?
  // Pricing
  featuredPrice   Float    @default(50) // SAR per featured ad
  withdrawalFee   Float    @default(0)
  minWithdrawal   Float    @default(100)
  // Messages
  welcomeMessage  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== NOTIFICATIONS SYSTEM =====

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // transaction, comment, favorite, system, payment, listing
  title      String
  message    String
  link       String?  // optional URL or context
  isRead     Boolean  @default(false)
  // Optional related entity
  relatedId  String?
  relatedType String?
  createdAt  DateTime @default(now())
}

// ===== ELECTRONIC PAYMENTS (Mada/Apple Pay/Visa/Mastercard) =====

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // What is being paid for
  purpose         String   // featured_listing, wallet_topup, service_fee
  listingId       String?  // for featured_listing
  amount          Float
  currency        String   @default("ريال")
  // Payment method
  method          String   // mada, apple_pay, visa, mastercard, stc_pay
  // Card info (last 4 digits only, never store full card)
  cardLast4       String?
  cardBrand       String?  // mada, visa, mastercard
  // Transaction reference (simulated)
  reference       String   @unique
  // Status
  status          String   @default("pending") // pending, completed, failed, refunded
  failureReason   String?
  // Admin/processor info
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


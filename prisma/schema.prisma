generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String   @unique
  password      String
  city          String?
  region        String?
  avatar        String?
  isVerified    Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  isDriver      Boolean  @default(false)
  isBlocked     Boolean  @default(false)
  blockedAt     DateTime?
  blockReason   String?
  walletBalance Float   @default(0)
  rating        Float   @default(5)
  tripsCount    Int     @default(0)
  currentLat    Float?
  currentLng    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips        Trip[]
  transactions Transaction[]
  bankAccounts BankAccount[]
  notifications Notification[]
  driver       Driver?
}

model Driver {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carModel      String
  carPlate      String
  carColor      String
  carYear       Int?
  licenseNumber String
  licenseExpiry DateTime?
  isOnline      Boolean  @default(false)
  isVerified    Boolean  @default(false)
  isApproved    Boolean  @default(false)
  approvalStatus String @default("pending")
  rejectionReason String?
  rating        Float   @default(5)
  tripsCount    Int     @default(0)
  earnings      Float   @default(0)
  currentLat    Float?
  currentLng    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents     DriverDocument[]
}

model DriverDocument {
  id            String   @id @default(cuid())
  driverId      String
  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type          String
  fileName      String
  fileUrl       String
  fileData      String?
  fileSize      Int?
  mimeType      String?
  status        String   @default("pending")
  uploadedAt    DateTime @default(now())

  @@index([driverId])
  @@index([type])
  @@index([status])
}

model Trip {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  driverId      String?
  
  serviceType   String   @default("ride")
  fromAddress   String
  fromCity      String?
  toAddress     String
  toCity        String?
  fromLat       Float?
  fromLng       Float?
  toLat         Float?
  toLng         Float?
  
  distance      Float    @default(0)
  duration      Int      @default(0)
  price         Float    @default(0)
  finalPrice    Float    @default(0)
  basePrice     Float    @default(0)
  surgeMultiplier Float  @default(1)
  
  status        String   @default("pending")
  paymentMethod String   @default("cash")
  paymentStatus String   @default("pending")
  
  cancellationLocked Boolean @default(false)
  cancellationRequest String?
  cancellationReason  String?
  
  rating        Int?
  review        String?
  
  driverArrivedAt DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  
  waitingMinutes  Int    @default(0)
  lateFee         Float  @default(0)
  freeWaitingMinutes Int @default(3)
  lateFeePerMinute Float  @default(2)
  
  cashReceived    Float?
  unpaidAmount    Float  @default(0)
  paymentConfirmed Boolean @default(false)
  unpaidReportedToAdmin Boolean @default(false)
  
  createdAt     DateTime @default(now())
  acceptedAt    DateTime?

  @@index([userId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([driverId, status])
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String
  amount        Float
  description   String
  status        String   @default("completed")
  tripId        String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([tripId])
  @@index([type])
  @@index([createdAt])
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bankName      String
  accountName   String
  iban          String?
  accountNumber String?
  accountType   String   @default("bank")
  paypalEmail   String?
  isDefault     Boolean  @default(false)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  tripId        String
  senderId      String
  receiverId    String
  message       String?
  messageType   String   @default("text")
  fileData      String?
  fileName      String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([tripId])
  @@index([senderId])
  @@index([receiverId])
  @@index([tripId, senderId])
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  title         String
  message       String
  type          String   @default("system")
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model ServicePrice {
  id        String   @id @default(cuid())
  serviceId String   @unique
  name      String
  basePrice Float    @default(8)
  perKm     Float    @default(1.5)
  perMin    Float    @default(0.25)
  minPrice  Float    @default(12)
  seats     Int      @default(4)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([isActive])
}

model SiteSettings {
  id              String  @id @default("default")
  commissionRate  Float   @default(15)
  vatRate         Float   @default(15)
  freeWaitingMin  Int     @default(5)
  lateFeePerMin   Float   @default(1)
  supportPhone    String  @default("0575015019")
  supportEmail    String  @default("support@uber.sa")
  adminEmail      String  @default("grouthhacker@gmail.com")
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("fixed") // fixed, percentage
  value       Float    // amount or percentage
  minTripPrice Float   @default(0)
  maxUses     Int      @default(1)
  usesCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdById String?  // admin who created
  appliedToId String?  // user it's applied to
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}
